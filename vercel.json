{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.js" }
  ],
  "crons": [
    { "path": "/cron/admin-report", "schedule": "0 8 */3 * *" },
    { "path": "/cron/donation-reminder", "schedule": "0 9 * * *" }
  ]
}